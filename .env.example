# HireTrack Production Environment Variables Example
# Copy this to your deployment platform settings (Render/Railway/etc)

DEBUG=False
SECRET_KEY=your_very_secret_random_key_here
ALLOWED_HOSTS=yourdomain.com,yourapp.onrender.com
DATABASE_URL=postgres://user:password@host:port/dbname
GROQ_API_KEY=your_groq_api_key
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://yourapp.onrender.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://yourapp.onrender.com
